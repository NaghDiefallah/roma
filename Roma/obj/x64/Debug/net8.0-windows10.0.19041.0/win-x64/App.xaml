<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Roma.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Roma"
    xmlns:converters="using:Roma.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value Converters -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:EmptyToColorConverter x:Key="EmptyToColorConverter" />
            <converters:StringVisibilityConverter x:Key="StringVisibilityConverter" />
            <converters:InverseStringVisibilityConverter x:Key="InverseStringVisibilityConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

