<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Roma.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Roma"
    xmlns:models="using:Roma.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ROMA">

    <!-- Temporarily commenting out MicaBackdrop to diagnose issue -->
    <!--
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>
    -->

    <Grid Background="#0D0D0F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Linear-Inspired Top Bar -->
        <Grid 
            x:Name="AppTitleBar"
            Grid.Row="0" 
            Height="64" 
            Padding="24,0,180,0"
            BorderBrush="#222226" 
            BorderThickness="0,0,0,1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Brand Section (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock 
                    Text="ROMA" 
                    FontSize="20" 
                    FontWeight="Bold" 
                    Foreground="White"
                    CharacterSpacing="40" />

                <Border 
                    Background="#1A1A1E" 
                    BorderBrush="#2A2A30" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="8,4">
                    <TextBlock 
                        Text="1.0.0" 
                        FontSize="11" 
                        Foreground="#6E6E78" 
                        FontWeight="Medium" />
                </Border>
            </StackPanel>

            <!-- Search Control (Center) -->
            <Grid Grid.Column="1" Margin="48,0" VerticalAlignment="Center">
                <Border 
                    Background="#161619" 
                    BorderBrush="#2A2A30" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Height="40">

                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <FontIcon 
                            Grid.Column="0" 
                            Glyph="&#xE721;" 
                            FontSize="14" 
                            Foreground="#6E6E78" 
                            Margin="0,0,12,0" />

                        <TextBox 
                            x:Name="SearchBox"
                            Grid.Column="1" 
                            PlaceholderText="Search servers by name, IP, or language..." 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Foreground="White" 
                            PlaceholderForeground="#6E6E78"
                            FontSize="13"
                            VerticalAlignment="Center"
                            TextChanged="SearchBox_TextChanged" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Filter Array (Right) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

                <!-- Recent Servers Button -->
                <Button 
                    x:Name="RecentServersButton"
                    Height="40"
                    Background="#161619" 
                    BorderBrush="#2A2A30" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Padding="16,0"
                    Click="RecentServersButton_Click"
                    ToolTipService.ToolTip="Recent Servers">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon 
                            Glyph="&#xE81C;" 
                            FontSize="14" 
                            Foreground="#6E6E78" />
                        <TextBlock 
                            Text="Recent" 
                            FontSize="13" 
                            Foreground="White" />
                    </StackPanel>
                </Button>

                <!-- Direct Connect Button -->
                <Button 
                    x:Name="DirectConnectButton"
                    Height="40"
                    Background="#161619" 
                    BorderBrush="#2A2A30" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Padding="16,0"
                    Click="DirectConnectButton_Click"
                    ToolTipService.ToolTip="Direct Connect">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon 
                            Glyph="&#xE8AD;" 
                            FontSize="14" 
                            Foreground="#6E6E78" />
                        <TextBlock 
                            Text="Direct Connect" 
                            FontSize="13" 
                            Foreground="White" />
                    </StackPanel>
                </Button>

                <!-- Filter Button with Flyout -->
                <Button 
                    x:Name="FilterButton"
                    Height="40"
                    Background="#161619" 
                    BorderBrush="#2A2A30" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Padding="16,0"
                    ToolTipService.ToolTip="Filters">
                    <Button.Flyout>
                        <Flyout x:Name="FilterFlyout" Placement="BottomEdgeAlignedRight">
                            <StackPanel Width="280" Spacing="16" Padding="8">
                                <TextBlock 
                                    Text="Filters" 
                                    FontSize="16" 
                                    FontWeight="SemiBold" 
                                    Foreground="White" />

                                <!-- Language Filter -->
                                <StackPanel Spacing="8">
                                    <TextBlock 
                                        Text="Language" 
                                        FontSize="13" 
                                        Foreground="#AFAFB4" 
                                        FontWeight="Medium" />
                                    <ComboBox 
                                        x:Name="LanguageFilter"
                                        Width="264"
                                        Background="#161619" 
                                        BorderBrush="#2A2A30" 
                                        BorderThickness="1" 
                                        CornerRadius="6"
                                        Foreground="White"
                                        FontSize="13"
                                        HorizontalAlignment="Stretch"
                                        SelectionChanged="LanguageFilter_SelectionChanged">
                                        <ComboBoxItem IsSelected="True">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🌐" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="All Languages" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇬🇧" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="English (EN)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇷🇺" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="Russian (RU)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇩🇪" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="German (DE)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇪🇸" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="Spanish (ES)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇵🇹" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="Portuguese (PT)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇫🇷" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="French (FR)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇮🇹" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="Italian (IT)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇵🇱" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="Polish (PL)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇹🇷" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="Turkish (TR)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="🇧🇷" FontSize="16" IsTextScaleFactorEnabled="False" />
                                                <TextBlock Text="Brazilian (BR)" />
                                            </StackPanel>
                                        </ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Gamemode Filter -->
                                <StackPanel Spacing="8">
                                    <TextBlock 
                                        Text="Gamemode" 
                                        FontSize="13" 
                                        Foreground="#AFAFB4" 
                                        FontWeight="Medium" />
                                    <ComboBox 
                                        x:Name="GamemodeFilter"
                                        Width="264"
                                        Background="#161619" 
                                        BorderBrush="#2A2A30" 
                                        BorderThickness="1" 
                                        CornerRadius="6"
                                        Foreground="White"
                                        FontSize="13"
                                        HorizontalAlignment="Stretch"
                                        SelectionChanged="GamemodeFilter_SelectionChanged">
                                        <ComboBoxItem Content="All Gamemodes" IsSelected="True" />
                                        <ComboBoxItem Content="Roleplay" />
                                        <ComboBoxItem Content="Freeroam" />
                                        <ComboBoxItem Content="Racing" />
                                        <ComboBoxItem Content="Deathmatch" />
                                        <ComboBoxItem Content="Drift" />
                                    </ComboBox>
                                </StackPanel>

                                <!-- Hide Empty Toggle -->
                                <ToggleSwitch 
                                    x:Name="HideEmptyToggle"
                                    Header="Hide empty servers"
                                    OnContent="On"
                                    OffContent="Off"
                                    Toggled="HideEmptyToggle_Toggled" />

                                <!-- Show Only Favorites Toggle -->
                                <ToggleSwitch 
                                    x:Name="ShowFavoritesToggle"
                                    Header="Show only favorites"
                                    OnContent="On"
                                    OffContent="Off"
                                    Toggled="ShowFavoritesToggle_Toggled" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon 
                            Glyph="&#xE71C;" 
                            FontSize="14" 
                            Foreground="#6E6E78" />
                        <TextBlock 
                            Text="Filters" 
                            FontSize="13" 
                            Foreground="White" />
                    </StackPanel>
                </Button>

                <!-- Refresh Button -->
                <Button 
                    x:Name="RefreshButton"
                    Width="40"
                    Height="40"
                    Background="#161619" 
                    BorderBrush="#2A2A30" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Click="RefreshButton_Click"
                    ToolTipService.ToolTip="Refresh server list">
                    <FontIcon 
                        Glyph="&#xE72C;" 
                        FontSize="16" 
                        Foreground="#6E6E78" />
                </Button>

                <!-- Settings Button -->
                <Button 
                    x:Name="SettingsButton"
                    Width="40"
                    Height="40"
                    Background="#161619" 
                    BorderBrush="#2A2A30" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Click="SettingsButton_Click">
                    <FontIcon 
                        Glyph="&#xE713;" 
                        FontSize="16" 
                        Foreground="#6E6E78" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Panel (Server List) -->
        <Grid Grid.Row="1" Padding="24,24,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Server Count -->
            <TextBlock 
                Grid.Row="0"
                Text="{x:Bind ServerCountText, Mode=OneWay}"
                FontSize="13"
                Foreground="#6E6E78"
                Margin="20,0,0,12"
                VerticalAlignment="Center" />

            <!-- Header Row -->
            <Grid 
                Grid.Row="1" 
                Height="40" 
                Padding="20,0"
                BorderBrush="#222226" 
                BorderThickness="0,0,0,1"
                Margin="0,0,0,8">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>

                <!-- Flag Header (Sortable) -->
                <Button 
                    Grid.Column="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="0,0,16,0"
                    Click="SortByFlag_Click"
                    VerticalAlignment="Center">
                    <TextBlock 
                        Text="FLAG" 
                        FontSize="11" 
                        FontWeight="SemiBold" 
                        Foreground="#6E6E78" 
                        CharacterSpacing="20" />
                </Button>

                <!-- Server Name Header (Sortable) -->
                <Button 
                    Grid.Column="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    Click="SortByName_Click"
                    VerticalAlignment="Center">
                    <TextBlock 
                        Text="SERVER" 
                        FontSize="11" 
                        FontWeight="SemiBold" 
                        Foreground="#6E6E78" 
                        CharacterSpacing="20" />
                </Button>

                <!-- Players Header (Sortable) -->
                <Button 
                    Grid.Column="2"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    Click="SortByPlayers_Click"
                    VerticalAlignment="Center">
                    <TextBlock 
                        Text="PLAYERS" 
                        FontSize="11" 
                        FontWeight="SemiBold" 
                        Foreground="#6E6E78" 
                        CharacterSpacing="20" />
                </Button>

                <!-- Language Header (Sortable) -->
                <Button 
                    Grid.Column="3"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    Click="SortByLanguage_Click"
                    VerticalAlignment="Center">
                    <TextBlock 
                        Text="LANGUAGE" 
                        FontSize="11" 
                        FontWeight="SemiBold" 
                        Foreground="#6E6E78" 
                        CharacterSpacing="20" />
                </Button>

                <TextBlock 
                    Grid.Column="4" 
                    Text="CONNECTION" 
                    FontSize="11" 
                    FontWeight="SemiBold" 
                    Foreground="#6E6E78" 
                    CharacterSpacing="20"
                    VerticalAlignment="Center" />
            </Grid>

            <!-- Virtualized Server List -->
            <ScrollViewer 
                Grid.Row="2" 
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">

                <ItemsRepeater 
                    x:Name="ServerList"
                    ItemsSource="{x:Bind FilteredServers, Mode=OneWay}"
                    VerticalAlignment="Top">

                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0" />
                    </ItemsRepeater.Layout>

                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:ServerItem">
                            <Grid 
                                Height="72" 
                                Padding="20,0"
                                BorderBrush="#222226" 
                                BorderThickness="0,0,0,1"
                                Background="Transparent"
                                DoubleTapped="ServerRow_DoubleTapped"
                                RightTapped="ServerRow_RightTapped">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>

                                <!-- Favorite Star (Far Left) -->
                                <FontIcon 
                                    Grid.Column="0"
                                    Glyph="&#xE735;" 
                                    FontSize="16" 
                                    Foreground="#FFD700"
                                    Visibility="{x:Bind FavoriteVisibility, Mode=OneWay}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0" />

                                <!-- Flag Image -->
                                <Image 
                                    Grid.Column="1"
                                    Width="20" 
                                    Height="15"
                                    Source="{x:Bind FlagUrl, Mode=OneTime}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0"
                                    Stretch="UniformToFill" />

                                <!-- Server Details -->
                                <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Center">
                                    <!-- Server Name with Tags -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock 
                                            Text="{x:Bind DisplayName, Mode=OneTime}" 
                                            FontSize="14" 
                                            FontWeight="Medium" 
                                            Foreground="White" 
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center"
                                            IsTextScaleFactorEnabled="False" />

                                        <!-- Tags -->
                                        <ItemsControl ItemsSource="{x:Bind Tags, Mode=OneTime}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <Border 
                                                        Background="#2A2A30" 
                                                        BorderBrush="#3A3A40" 
                                                        BorderThickness="1" 
                                                        CornerRadius="4" 
                                                        Padding="6,2">
                                                        <TextBlock 
                                                            Text="{x:Bind}" 
                                                            FontSize="10" 
                                                            FontWeight="Medium" 
                                                            Foreground="#AFAFB4" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <TextBlock 
                                        Text="{x:Bind AddressText, Mode=OneTime}" 
                                        FontSize="12" 
                                        Foreground="#6E6E78" 
                                        FontFamily="Consolas" />
                                </StackPanel>

                                <!-- Capacity -->
                                <StackPanel Grid.Column="3" Spacing="4" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Ellipse 
                                            Width="6" 
                                            Height="6" 
                                            Fill="White" />

                                        <TextBlock 
                                            Text="{x:Bind CapacityText, Mode=OneTime}" 
                                            FontSize="13" 
                                            Foreground="White" 
                                            FontFamily="Consolas" />
                                    </StackPanel>

                                    <!-- Ping -->
                                    <TextBlock 
                                        Text="{x:Bind PingText, Mode=OneWay}" 
                                        FontSize="11" 
                                        Foreground="#6E6E78" 
                                        FontFamily="Consolas"
                                        HorizontalAlignment="Left"
                                        Margin="14,0,0,0" />
                                </StackPanel>

                                <!-- Language -->
                                <TextBlock 
                                    Grid.Column="4" 
                                    Text="{x:Bind LanguageDisplay, Mode=OneTime}" 
                                    FontSize="13" 
                                    FontWeight="Medium" 
                                    Foreground="#AFAFB4" 
                                    VerticalAlignment="Center" />

                                <!-- Connect Button -->
                                <Button 
                                    Grid.Column="5"
                                    Content="Connect" 
                                    Height="36"
                                    Padding="20,0"
                                    Background="Transparent" 
                                    BorderBrush="#2A2A30" 
                                    BorderThickness="1" 
                                    CornerRadius="6"
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="Medium"
                                    Click="ConnectButton_Click"
                                    Tag="{x:Bind Mode=OneTime}"
                                    VerticalAlignment="Center">

                                    <Button.Resources>
                                        <ResourceDictionary>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver">White</SolidColorBrush>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver">Black</SolidColorBrush>
                                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver">White</SolidColorBrush>
                                        </ResourceDictionary>
                                    </Button.Resources>
                                </Button>

                                <!-- Row Hover Effect -->
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup>
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Background" Value="#161619" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>

        <!-- Loading Indicator -->
        <Grid 
            x:Name="LoadingOverlay"
            Grid.RowSpan="2"
            Background="#99000000"
            Visibility="Collapsed">
            <StackPanel 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Spacing="16">
                <ProgressRing 
                    IsActive="True" 
                    Width="48" 
                    Height="48" 
                    Foreground="White" />
                <TextBlock 
                    Text="Loading servers..." 
                    FontSize="14" 
                    Foreground="White" />
            </StackPanel>
        </Grid>

        <!-- Recent Servers Overlay -->
        <Grid 
            x:Name="RecentServersOverlay"
            Grid.RowSpan="2"
            Background="#DD000000"
            Visibility="Collapsed">

            <Border
                MaxWidth="700"
                MaxHeight="600"
                Background="#0D0D0F"
                BorderBrush="#2A2A30"
                BorderThickness="1"
                CornerRadius="12"
                Padding="32"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock 
                            Text="Recent Servers"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="White"
                            HorizontalAlignment="Left" />
                        <Button
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="32"
                            Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            Foreground="#6E6E78"
                            HorizontalAlignment="Right"
                            Click="CloseRecentServersOverlay_Click"
                            ToolTipService.ToolTip="Close" />
                    </Grid>

                    <!-- Content -->
                    <ScrollViewer 
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        MaxHeight="400">
                        <StackPanel x:Name="RecentServersPanel" Spacing="12" />
                    </ScrollViewer>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2" Margin="0,24,0,0" Spacing="12">
                        <Button
                            x:Name="ClearRecentButton"
                            Content="Clear History"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="#8B0000"
                            Foreground="#FF4539"
                            Height="40"
                            Click="ClearRecentServers_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
